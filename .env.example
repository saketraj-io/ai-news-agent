# ──────────────────────────────────────────────────────────────────
# AI News Agent — Environment Variables Template
# Copy this file to `.env` and fill in your real API keys.
# NEVER commit `.env` to version control.
# ──────────────────────────────────────────────────────────────────

# ── Google Gemini ──────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── GNews API ──────────────────────────────────────────────────────
# Free tier: 100 req/day (10 results per req)  |  https://gnews.io/register
GNEWS_API_KEY=your_gnews_api_key_here

# ── App Settings (optional overrides) ─────────────────────────────
# Gemini model name (options: gemini-1.5-flash, gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-flash

# Max articles to fetch per topic per run
MAX_ARTICLES_PER_TOPIC=10

# SQLite database file path (relative to project root)
DB_PATH=data/news_agent.db

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
